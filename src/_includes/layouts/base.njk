<!DOCTYPE html>
<html lang="en">
  <head>
    <!-- Standard meta tags -->
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ description if description else 'Rocky Mountain Thai Kitchen is an authentic Thai restaurant in Leadville, CO. Flavorful dishes made with care in the heart of the Colorado Rockies — dine in or order online today.' }}">
    <meta name="keywords" content="Thai restaurant Leadville CO, Thai food Colorado, Rocky Mountain Thai Kitchen, Thai cuisine Leadville, best Thai food Colorado mountains, Thai restaurant near me Leadville">
    <link rel="canonical" href="{{ client.domain }}{{ page.url }}">

    <!-- Social Media Display -->
    <meta property="og:title" content="{{ title if title != 'Home' else 'Rocky Mountain Thai Kitchen | Authentic Thai Cuisine — Leadville, CO' }}"/>
    <meta property="og:description" content="{{ description if description else 'Authentic Thai cuisine in Leadville, CO. Flavorful dishes made with care in the heart of the Colorado Rockies.' }}"/>
    <meta property="og:type" content="restaurant"/>
    <meta property="og:url" content="{{ client.domain }}{{ page.url }}"/>
    <meta property="og:image" content="{{ client.domain }}/assets/images/og-image.webp"/>
    <meta property="og:image:secure_url" content="{{ client.domain }}/assets/images/og-image.webp"/>
    <meta property="og:locale" content="en_US"/>
    <meta property="og:site_name" content="Rocky Mountain Thai Kitchen — Leadville, CO"/>

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content="{{ title if title != 'Home' else 'Rocky Mountain Thai Kitchen | Authentic Thai Cuisine — Leadville, CO' }}"/>
    <meta name="twitter:description" content="{{ description if description else 'Authentic Thai cuisine in Leadville, CO. Flavorful dishes made with care in the heart of the Colorado Rockies.' }}"/>
    <meta name="twitter:image" content="{{ client.domain }}/assets/images/og-image.webp"/>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="{{ '/assets/favicons/apple-touch-icon.png' | url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ '/assets/favicons/favicon-32x32.png' | url }}?v1">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ '/assets/favicons/favicon-16x16.png' | url }}">
    <link rel="manifest" href="{{ '/assets/favicons/site.webmanifest' | url }}">
    <meta name="msapplication-TileColor" content="#141e21">
    <meta name="theme-color" content="#141e21">

    <!-- Sitewide Stylesheets and Scripts -->
    <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
    <link rel="stylesheet" href="{{ '/assets/css/brand.css' | url }}">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Acme&family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400..900&family=Cormorant+Garamond:ital,wght@0,300;1,300&family=Luckiest+Guy&family=Nunito:ital,wght@0,200..1000;1,200..1000&family=Quicksand:wght@300..700&family=Rammetto+One&family=Roboto:ital,wght@0,100..900;1,100..900&family=Slackey&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&family=Staatliches&family=UnifrakturMaguntia&display=swap" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    {% block head %}{% endblock %}

    <title>{% if title == "Home" %}Rocky Mountain Thai Kitchen | Authentic Thai Cuisine — Leadville, CO{% else %}{{ title }} | Rocky Mountain Thai Kitchen — Leadville, CO{% endif %}</title>

    <!-- Restaurant Schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Restaurant",
        "name": "{{ client.name }}",
        "description": "Authentic Thai home cooking in Leadville, CO. Founded by Phean Deejun and Somneuk Mongkol, both born in Thailand, serving traditional curries, stir-fries, and noodle dishes at 422 Harrison Ave.",
        "url": "{{ client.domain }}",
        "telephone": "{{ client.phone }}",
        "email": "{{ client.email }}",
        "servesCuisine": ["Thai", "Southeast Asian"],
        "priceRange": "{{ client.priceRange }}",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "{{ client.address.street }}",
          "addressLocality": "{{ client.address.city }}",
          "addressRegion": "{{ client.address.stateAbbr }}",
          "postalCode": "{{ client.address.zip }}",
          "addressCountry": "US"
        },
        "logo": "{{ client.domain }}/assets/images/logo.png",
        "image": "{{ client.domain }}/assets/images/og-image.webp",
        "hasMap": "https://maps.google.com/?q=Rocky+Mountain+Thai+Kitchen+Leadville+CO",
        "reservationUrl": "{{ client.reservationUrl }}",
        "areaServed": [
          { "@type": "City", "name": "Leadville" },
          { "@type": "City", "name": "Buena Vista" },
          { "@type": "City", "name": "Breckenridge" },
          { "@type": "City", "name": "Fairplay" },
          { "@type": "City", "name": "Salida" }
        ]
      }
    </script>

    <!-- ADD GOOGLE ANALYTICS -->

    <!-- Prevent scroll restoration flash -->
    <script>if (history.scrollRestoration) history.scrollRestoration = 'manual';</script>

  </head>

  <body class="overflow-x-hidden">
    {% include "components/header.njk" %}
    <main>
      {% block content %}{% endblock %}
    </main>
    {% include "components/footer.njk" %}
    <script src="{{ '/assets/js/main.js' | url }}"></script>
  </body>
</html>
