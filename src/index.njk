---
title: Home
description: "Rocky Mountain Thai Kitchen in Leadville, CO serves authentic Thai home cooking from owners born in Thailand. Fresh curries, stir-fries, and noodle dishes at 422 Harrison Ave. Dine in or order online."
---

{% extends "layouts/base.njk" %}

{% block head %}
<script id="marketing-popup-script" data-restaurant-id="1154" src="https://88restaurants.com/uploads/popup.js"></script>

<script>
document.addEventListener("DOMContentLoaded", async () => {
  console.log("sup")
  try {
    const response = await fetch(
      "https://88restaurants.com/restaurants/1154/online_orders/discount_button"
    );
    const html = await response.text();
    document.body.insertAdjacentHTML("beforeend", html);
  } catch (error) {
    console.error("Error fetching button:", error);
  }
});
</script>

{% endblock %}

{% block content %}

  <!-- Hero -->
  <section id="hero" class="relative overflow-hidden min-h-screen" style="min-height: 100vh;">
    <!-- Slideshow -->
    <div id="hero-slides" class="absolute inset-0">
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000" style="background-image: url('{{ '/assets/images/interior-3.jpg' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/thai-food-1.jpg' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/interior-1.jpg' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/thai-food-2.jpg' | url }}'); background-size: cover; background-position: center;"></div>
      <div class="hero-slide absolute inset-0 transition-opacity duration-1000 opacity-0" style="background-image: url('{{ '/assets/images/interior-2.jpg' | url }}'); background-size: cover; background-position: center;"></div>
    </div>
    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-dark-bg opacity-50"></div>
    <div class="relative flex flex-col items-center justify-center min-h-screen px-4 text-center">
      <img src="{{ '/assets/images/logo.png' | url }}" alt="Rocky Mountain Thai Kitchen" class="w-full max-w-[200px] md:max-w-sm lg:max-w-lg mb-10 drop-shadow-lg">
      <a href="{{ '/menu' | url }}"
        class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-white border border-white hover:bg-accent hover:text-dark-bg hover:border-accent focus:outline-none transition-colors duration-300">
        View Our Menu
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="bg-white">
    <div class="mx-auto max-w-screen-xl md:grid md:grid-cols-2 gap-0">

      <!-- About image (right on desktop) -->
      <div class="flex items-center justify-center p-6 md:p-10 md:order-last">
        <div class="about-collage relative w-full max-w-[520px]" data-animate="about-collage">
          <img src="{{ '/assets/images/about-oval.png' | url }}" alt="Rocky Mountain Thai Kitchen" class="about-oval w-full h-auto">
          <img src="{{ '/assets/images/about-food-circle.png' | url }}" alt="Pad thai at Rocky Mountain Thai Kitchen" class="about-circle about-circle-food absolute top-[-4%] right-[-6%] w-[40%]">
          <img src="{{ '/assets/images/about-logo-circle.png' | url }}" alt="Rocky Mountain Thai Kitchen logo" class="about-circle about-circle-logo absolute bottom-[-2%] left-[-6%] w-[38%]">
        </div>
      </div>

      <!-- Text (right) -->
      <div class="flex flex-col justify-center px-8 py-16 lg:px-14">
        <div data-animate="fade-up">
          <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-4">About Us</p>
          <h2 class="text-5xl md:text-6xl text-gray-900 mb-8">Welcome to Rocky Mountain Thai Kitchen</h2>
          <p class="text-gray-700 font-light text-xl leading-relaxed mb-6">
            Rocky Mountain Thai Kitchen is the vision of Phean Deejun and Somneuk Mongkol — a couple born in Thailand who traveled the world before planting roots in Leadville. After meeting aboard a Princess Cruises ship and later honing their craft at restaurants in California and Colorado, they hit the road with a food truck before opening their doors on Harrison Ave. in February 2025.
          </p>
          <p class="text-gray-700 font-light text-xl leading-relaxed">
            Their mission is simple: serve Thai food that tastes like home. From coconut milk curries to fresh basil stir-fries, every dish is made with authentic ingredients — some sourced all the way from Denver. The restaurant's warm decor blends photos of Thailand with images of Leadville's own history, a true reflection of the home they've built here. The local welcome has been nothing short of incredible.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hours -->
  <section class="relative overflow-hidden border-t border-gray-800" style="background-image: url('{{ '/assets/images/ingredients.jpg' | url }}'); background-size: cover; background-position: center;">
    <div class="absolute inset-0 bg-dark-bg opacity-70"></div>
    <div class="relative max-w-screen-xl px-4 py-16 mx-auto md:py-24">
      <div class="grid md:grid-cols-2 gap-10 mx-auto" style="max-width: 48rem;">

        <!-- Lunch -->
        <div data-animate="fade-up" class="text-center">
          <h2 class="font-cormorant uppercase tracking-widest text-6xl text-accent mb-6">Lunch Hours</h2>
          <div class="text-2xl text-gray-300 font-light space-y-2">
            <p class="text-white font-normal">Mon & Wed – Sun</p>
            <p>11:00 am – 3:00 pm</p>
          </div>
        </div>

        <!-- Dinner -->
        <div data-animate="fade-up" style="--animate-delay: 150ms" class="text-center">
          <h2 class="font-cormorant uppercase tracking-widest text-6xl text-accent mb-6">Dinner Hours</h2>
          <div class="text-2xl text-gray-300 font-light space-y-2">
            <p class="text-white font-normal">Mon & Wed – Sun</p>
            <p>4:30 pm – 9:00 pm</p>
          </div>
        </div>

      </div>
      <p data-animate="fade-up" style="--animate-delay: 300ms" class="text-center text-gray-400 font-light text-xl tracking-widest uppercase mt-12">Closed Tuesdays</p>
    </div>
  </section>

  <!-- Menu -->
  <section class="bg-stone-50 border-t border-stone-200">
    <div class="max-w-5xl mx-auto px-8 py-16 md:py-20 flex flex-col md:flex-row items-center gap-10">

      <!-- Image (left) -->
      <div data-animate="fade-left" class="shrink-0 w-full md:w-[400px]">
        <img src="{{ '/assets/images/shrimp.png' | url }}" alt="Thai shrimp dish at Rocky Mountain Thai Kitchen" class="w-full h-auto rounded-xl object-cover">
      </div>

      <!-- Text (right) -->
      <div data-animate="fade-up" class="flex flex-col justify-center">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Explore</p>
        <h2 class="text-5xl md:text-6xl text-gray-900 mb-6">Our Menu</h2>
        <p class="text-gray-700 font-light text-xl leading-relaxed mb-8">
          From fragrant curries and fresh pad thai to classic stir-fries and soups, every dish is made with authentic ingredients and a whole lot of heart. There's something for everyone — come hungry.
        </p>
        <div>
          <a href="{{ '/menu/' | url }}"
            class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center gap-3 px-10 py-4 text-2xl font-medium text-white rounded-full transition-colors duration-300"
            style="background-color: var(--green);">
            View Our Menu <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Gallery Strip -->
  <section class="gallery-strip-section relative overflow-hidden" style="height: 220px; background: #4a9db8;">
    <div class="gallery-strip-track" id="galleryStripTrack">
      {% set stripImages = [
        "g1.jpg","g2.jpg","g3.jpg","g4.jpg","g5.jpg",
        "g6.jpg","g7.jpg","g8.jpg","g9.jpg","g10.jpg",
        "g11.jpg","g12.jpg","g13.jpg","g14.jpg","g15.jpg",
        "g16.jpg","g17.jpg","g18.jpg"
      ] %}
      {% for img in stripImages %}
        <img src="{{ ('/assets/images/gallery/' + img) | url }}" alt="" loading="lazy">
      {% endfor %}
      {# Duplicate for seamless loop #}
      {% for img in stripImages %}
        <img src="{{ ('/assets/images/gallery/' + img) | url }}" alt="" loading="lazy" aria-hidden="true">
      {% endfor %}
    </div>
    <!-- Hover overlay -->
    <div class="gallery-strip-overlay">
      <a href="{{ '/gallery' | url }}" class="font-cormorant uppercase tracking-widest text-lg text-white border border-white px-8 py-3 hover:bg-accent hover:text-dark-bg hover:border-accent transition-colors duration-300">
        View Gallery
      </a>
    </div>
    <style>
      .gallery-strip-track {
        display: flex;
        gap: 6px;
        height: 100%;
        width: max-content;
        animation: gallery-scroll 120s linear infinite;
      }
      .gallery-strip-track img {
        height: 100%;
        width: auto;
        object-fit: cover;
        display: block;
        flex-shrink: 0;
      }
      @keyframes gallery-scroll {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      .gallery-strip-section:hover .gallery-strip-track {
        animation-play-state: paused;
      }
      .gallery-strip-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0,0,0,0);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: background 0.3s ease, opacity 0.3s ease;
        pointer-events: none;
      }
      .gallery-strip-section:hover .gallery-strip-overlay {
        background: rgba(0,0,0,0.55);
        opacity: 1;
        pointer-events: auto;
      }
    </style>
  </section>

  <!-- Reservations -->
  <section id="reservations" style="background-color: #fff4e6;">
    <div class="max-w-screen-xl mx-auto px-8 py-16 md:py-20">

      <!-- Header row -->
      <div data-animate="fade-up" class="text-center mb-12">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Book Your Experience</p>
        <h2 class="text-5xl md:text-6xl text-gray-900">Reserve a Table</h2>
      </div>

      <!-- Content row: text left, widget right -->
      <div class="flex flex-col md:flex-row gap-12 items-start justify-center">
        <div data-animate="fade-left" class="flex-1 max-w-md">
          <p class="text-gray-600 font-light text-xl leading-relaxed mb-6">Join us for dinner at Rocky Mountain Thai Kitchen — Leadville's destination for authentic Thai cuisine. Reservations are recommended, especially on weekends.</p>
          <p class="text-gray-600 font-light text-xl leading-relaxed mb-6">Use the widget to check availability and book your table in just a few clicks. Our reservations are managed through 88 Restaurants, making it easy to plan your visit ahead of time.</p>
          <p class="text-gray-500 font-light text-xl">Dining with a group of 11 or more? <a href="{{ '/parties/' | url }}" class="text-accent hover:text-gray-900 underline underline-offset-2 transition-colors duration-300">Fill out our party inquiry form</a> for a tailored experience.</p>
        </div>
        <div data-animate="fade-right" class="shrink-0 flex justify-center">
          <iframe id="widget" width="300" height="442" src="https://88restaurants.com/1155/widgets/5155" style="border: none; background: none; border-radius: 5px;"></iframe>
        </div>
      </div>

    </div>
  </section>

  <!-- Private Events -->
  <section style="background-color: #fff4e6;">
    <div class="max-w-screen-xl mx-auto px-8 py-6 md:py-8">
      <div data-animate="fade-up" class="rounded-3xl p-10 md:p-14 flex flex-col md:flex-row gap-10 md:gap-0" style="background-color: var(--green);">

        <!-- Left: elephant image -->
        <div class="shrink-0 md:pr-12 md:border-r border-white/30 flex items-center justify-center">
          <img src="{{ '/assets/images/white-elephant.png' | url }}" alt="Rocky Mountain Thai Kitchen" class="w-[200px] h-auto">
        </div>

        <!-- Right: title + text + button -->
        <div class="flex-1 md:pl-12 flex flex-col justify-center">
          <p class="font-cormorant uppercase tracking-widest text-base text-white/70 mb-3">Celebrate With Us</p>
          <h2 class="text-5xl md:text-6xl text-white mb-6">Private Events</h2>
          <p class="text-white/90 font-light text-xl leading-relaxed mb-8">
            Planning a birthday, corporate dinner, or special celebration? Rocky Mountain Thai Kitchen offers a warm setting for private and group events. Let us craft an unforgettable experience tailored to your occasion.
          </p>
          <div>
            <a href="{{ '/parties/' | url }}"
              class="font-cormorant uppercase tracking-widest inline-flex items-center justify-center px-8 py-3 text-lg font-medium text-white rounded-full border border-white hover:bg-white hover:text-[#52a875] transition-colors duration-300">
              Inquire About Events
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" style="background-color: #fff4e6;">
    <div class="flex min-h-[600px]">

      <!-- Left: image -->
      <div data-animate="fade-left" class="hidden md:block w-1/2 shrink-0 relative">
        <img src="{{ '/assets/images/contact.jpg' | url }}" alt="Rocky Mountain Thai Kitchen" class="absolute inset-0 w-full h-full object-cover">
      </div>

      <!-- Right: heading + info + form -->
      <div data-animate="fade-up" class="flex flex-col justify-center px-8 py-16 lg:px-14 w-full md:w-1/2">
        <p class="font-cormorant uppercase tracking-widest text-base text-accent mb-3">Get In Touch</p>
        <h2 class="text-5xl md:text-6xl text-gray-900 mb-8">Contact Us</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-10">
          <!-- Address -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Address</h4>
            <div class="text-base text-gray-600 font-light space-y-1">
              <p>{{ client.address.street }}</p>
              <p>{{ client.address.city }}, {{ client.address.stateAbbr }} {{ client.address.zip }}</p>
              <a href="https://maps.google.com/?q={{ client.address.street | replace(' ', '+') }}+{{ client.address.city | replace(' ', '+') }}+{{ client.address.stateAbbr }}+{{ client.address.zip }}" target="_blank" rel="noopener noreferrer" class="inline-block mt-3 text-sm font-cormorant uppercase tracking-widest text-accent hover:text-gray-900 transition-colors duration-300">Get Directions →</a>
            </div>
          </div>
          <!-- Contact -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Phone</h4>
            <div class="text-base text-gray-600 font-light space-y-2">
              <p><a href="tel:{{ client.phone }}" class="hover:text-gray-900 transition-colors duration-300">{{ client.phone }}</a></p>
            </div>
          </div>
          <!-- Socials -->
          <div>
            <h4 class="font-cormorant uppercase tracking-widest text-2xl text-accent mb-3">Follow Us</h4>
            <div class="text-base text-gray-600 font-light space-y-2">
              {% if client.social.facebook %}<p><a href="{{ client.social.facebook }}" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors duration-300"><i class="bi bi-facebook"></i> Facebook</a></p>{% endif %}
              {% if client.social.instagram %}<p><a href="{{ client.social.instagram }}" target="_blank" rel="noopener noreferrer" class="hover:text-gray-900 transition-colors duration-300"><i class="bi bi-instagram"></i> Instagram</a></p>{% endif %}
            </div>
          </div>
        </div>

        <iframe src="https://88restaurants.com/1155/contact_forms" frameborder="0" width="100%" height="545" scrolling="no" style="border-radius: 10px;"></iframe>
      </div>

    </div>
  </section>

{% endblock %}
